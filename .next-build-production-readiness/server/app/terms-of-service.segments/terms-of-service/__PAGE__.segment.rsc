6:["$","section","3. Using Mechi fairly",{"className":"card p-5 sm:p-6","children":[["$","h2",null,{"className":"text-xl font-black text-[var(--text-primary)]","children":"3. Using Mechi fairly"}],["$","div",null,{"className":"mt-3 space-y-3","children":[["$","p","Mechi is built for organized competition and player coordination. You agree not to misuse the platform or interfere with fair play.",{"className":"text-sm leading-7 text-[var(--text-secondary)] sm:text-base","children":"Mechi is built for organized competition and player coordination. You agree not to misuse the platform or interfere with fair play."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-[var(--text-secondary)] sm:text-base","children":[["$","li","Do not cheat, exploit bugs, manipulate rankings, fix matches, submit false reports, or interfere with tournament or queue integrity.",{"className":"flex gap-3","children":[["$","span",null,{"className":"mt-2 h-2 w-2 rounded-full bg-[var(--brand-teal)]"}],["$","span",null,{"children":"Do not cheat, exploit bugs, manipulate rankings, fix matches, submit false reports, or interfere with tournament or queue integrity."}]]}],["$","li","Do not harass, threaten, scam, spam, or post unlawful, abusive, or infringing content.",{"className":"flex gap-3","children":[["$","span",null,{"className":"mt-2 h-2 w-2 rounded-full bg-[var(--brand-teal)]"}],["$","span",null,{"children":"Do not harass, threaten, scam, spam, or post unlawful, abusive, or infringing content."}]]}],["$","li","Do not attempt unauthorized access, reverse engineer restricted systems, scrape the service in prohibited ways, or disrupt the platform through bots, malware, or attacks.",{"className":"flex gap-3","children":[["$","span",null,{"className":"mt-2 h-2 w-2 rounded-full bg-[var(--brand-teal)]"}],["$","span",null,{"children":"Do not attempt unauthorized access, reverse engineer restricted systems, scrape the service in prohibited ways, or disrupt the platform through bots