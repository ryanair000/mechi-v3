{
  "name": "mechi-v3",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "android:dev": "npm --prefix apps/android run start",
    "android:emulator": "npm --prefix apps/android run android",
    "android:typecheck": "npm --prefix apps/android run typecheck",
    "build": "next build --webpack",
    "start": "next start",
    "import:registrations": "node ./scripts/import-registration-feed.mjs",
    "ops:instagram:check": "node ./scripts/openclaw-instagram-check.mjs",
    "ops:registrations": "node ./scripts/openclaw-supabase-summary.mjs",
    "ops:tournaments": "node ./scripts/openclaw-tournaments-summary.mjs",
    "ops:whatsapp-qr": "node ./scripts/openclaw-whatsapp-qr.mjs",
    "start:e2e": "npm run build && npm run start",
    "lint": "eslint",
    "test:e2e": "node ./e2e/scripts/run-playwright.mjs",
    "test:e2e:public-auth": "node ./e2e/scripts/run-playwright.mjs --project=desktop-core e2e/specs/public-auth.spec.ts",
    "test:e2e:player-desktop": "node ./e2e/scripts/run-playwright.mjs --project=desktop-core e2e/specs/player-pages.spec.ts e2e/specs/competition-flows.spec.ts",
    "test:e2e:player-mobile": "node ./e2e/scripts/run-playwright.mjs --project=mobile-core",
    "test:e2e:core": "node ./e2e/scripts/run-playwright.mjs --project=desktop-core --project=mobile-core",
    "test:e2e:admin": "node ./e2e/scripts/run-playwright.mjs --project=admin",
    "test:e2e:provider-mock": "node ./e2e/scripts/run-playwright.mjs --project=providers-mock",
    "test:e2e:provider-sandbox": "node ./e2e/scripts/run-playwright.mjs --provider-mode=sandbox --project=providers-sandbox",
    "test:e2e:cross-browser": "node ./e2e/scripts/run-playwright.mjs --project=cross-browser-chromium --project=cross-browser-firefox --project=cross-browser-webkit",
    "test:e2e:headed": "node ./e2e/scripts/run-playwright.mjs --headed",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:e2e:install": "playwright install chromium firefox webkit"
  },
  "dependencies": {
    "@mux/mux-node": "^14.0.1",
    "@mux/mux-player-react": "^3.11.8",
    "@number-flow/react": "^0.6.0",
    "@paper-design/shaders-react": "^0.0.76",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.2",
    "resend": "6.1.3",
    "socket.io-client": "^4.8.3",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  },
  "description": "This is a [Next.js](https://nextjs.org) project bootstrapped with [`create-next-app`](https://nextjs.org/docs/app/api-reference/cli/create-next-app).",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanair000/mechi-v3.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ryanair000/mechi-v3/issues"
  },
  "homepage": "https://github.com/ryanair000/mechi-v3#readme",
  "overrides": {
