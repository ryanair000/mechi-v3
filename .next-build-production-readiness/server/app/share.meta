{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/share/layout,_N_T_/(app)/share/page,_N_T_/share"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/share/__PAGE__",
    "/!KGFwcCk/share",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}