# Existing app secrets omitted here for brevity.
# Add the values below to your local or hosted environment before enabling Instagram DMs.

INSTAGRAM_GRAPH_API_VERSION=v25.0
# Used by /api/webhooks/instagram and /api/instagram/webhook.
INSTAGRAM_VERIFY_TOKEN=replace-with-a-random-shared-secret
# Optional alias; when blank, INSTAGRAM_VERIFY_TOKEN is used.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=replace-with-a-random-shared-secret
INSTAGRAM_APP_SECRET=your-meta-app-secret
MECHI_INSTAGRAM_ACCESS_TOKEN=your-instagram-user-token
MECHI_INSTAGRAM_USER_ID=your-instagram-professional-account-id
MECHI_INSTAGRAM_APP_ID=your-meta-app-id
MECHI_INSTAGRAM_APP_SECRET=your-meta-app-secret
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_PAGE_ACCESS_TOKEN=your-page-access-token-with-instagram-messaging-access
INSTAGRAM_AI_AUTO_REPLY_ENABLED=false

OPENCLAW_WEBHOOK_URL=https://your-openclaw-endpoint.example.com/webhooks/instagram
OPENCLAW_API_KEY=
OPENCLAW_TIMEOUT_MS=15000
MECHI_OPENCLAW_BRIDGE_URL=https://your-openclaw-endpoint.example.com/v1/mechi-support-reply
MECHI_OPENCLAW_BRIDGE_TOKEN=
INSTAGRAM_FALLBACK_REPLY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@mechi.club

TELEGRAM_BOT_TOKEN=
# Telegram supergroup or channel chat id. For groups this is usually a negative -100... id.
TELEGRAM_CHAT_ID=
# Optional topic id inside the Telegram group for new registrations.
TELEGRAM_REGISTRATION_THREAD_ID=
# Optional topic id inside the Telegram group for new test issue reports and fixed updates.
TELEGRAM_TEST_REPORT_THREAD_ID=
# Optional display names used in Telegram test report notifications.
TELEGRAM_TEST_REPORTER_LABEL=
TELEGRAM_TEST_FIXER_LABEL=

# Optional dedicated Telegram token for the OpenClaw host poller.
# Falls back to TELEGRAM_BOT_TOKEN when omitted.
MECHI_OPENCLAW_TELEGRAM_BOT_TOKEN=
# support = customer-safe Telegram helper with built-in Mechi product context.
# direct = operator control chat; pair with MECHI_OPENCLAW_TELEGRAM_AGENT=default/main and an allowlist.
MECHI_OPENCLAW_TELEGRAM_MODE=support
# Use support for customer-safe replies, or default/main for full-control repo access in direct mode.
MECHI_OPENCLAW_TELEGRAM_AGENT=support
MECHI_OPENCLAW_TELEGRAM_MODEL=openai-codex/gpt-5.5
MECHI_OPENCLAW_TELEGRAM_TIMEOUT_SECONDS=120
MECHI_OPENCLAW_TELEGRAM_POLL_TIMEOUT_SECONDS=25
MECHI_OPENCLAW_TELEGRAM_RETRY_DELAY_MS=3000
MECHI_OPENCLAW_TELEGRAM_ALLOWED_CHAT_TYPES=private
# Optional comma-separated Telegram chat ids allowed to talk to the poller.
MECHI_OPENCLAW_TELEGRAM_ALLOWED_CHAT_IDS=
MECHI_OPENCLAW_TELEGRAM_DELETE_WEBHOOK=true

NEXT_PUBLIC_APP_URL=https://mechi.club
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Used by the OpenClaw control agent live registration helper:
# npm run ops:registrations -- --json
GH_TOKEN=
GITHUB_TOKEN=
GH_REPO=ryanair000/mechi-v3
# Used by the OpenClaw control agent GitHub skill and gh CLI wiring.
MECHI_OBSIDIAN_VAULT=mechi-ops
MECHI_OBSIDIAN_VAULT_PATH=/home/ubuntu/.openclaw/vaults/mechi-ops
EDITOR=/usr/bin/cat
# Used by the OpenClaw control agent Obsidian skill on the headless host.
NEXT_PUBLIC_TESTS_URL=https://tests.mechi.club
NEXT_PUBLIC_WHATSAPP_JOIN_URL=
NEXT_PUBLIC_CHEZAHUB_URL=
NEXT_PUBLIC_MUX_ENV_KEY=

MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=
