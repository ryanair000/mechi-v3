{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/games/layout,_N_T_/(app)/games/page,_N_T_/games"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/games/__PAGE__",
    "/!KGFwcCk/games",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}