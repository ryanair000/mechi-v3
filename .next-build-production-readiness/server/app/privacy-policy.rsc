15:["$","section","4. Data retention",{"className":"card p-5 sm:p-6","children":[["$","h2",null,{"className":"text-xl font-black text-[var(--text-primary)]","children":"4. Data retention"}],["$","div",null,{"className":"mt-3 space-y-3","children":[["$","p","We keep information for as long as we reasonably need it to operate Mechi, maintain competition records, resolve disputes, meet legal or accounting requirements, and protect against fraud or abuse.",{"className":"text-sm leading-7 text-[var(--text-secondary)] sm:text-base","children":"We keep information for as long as we reasonably need it to operate Mechi, maintain competition records, resolve disputes, meet legal or accounting requirements, and protect against fraud or abuse."}],["$","p","Retention periods can vary depending on the kind of data involved. For example, account records, payment records, moderation logs, and tournament outcomes may be kept longer than routine analytics data.",{"className":"text-sm leading-7 text-[var(--text-secondary)] sm:text-base","children":"Retention periods can vary depending on the kind of data involved. For example, account records, payment records, moderation logs, and tournament outcomes may be kept longer than routine analytics data."}]]}],null]}]
16:["$","section","5. Your choices and rights",{"className":"card p-5 sm:p-6","children":[["$","h2",null,{"className":"text-xl font-black text-[var(--text-primary)]","children":"5. Your choices and rights"}],["$","div",null,{"className":"mt-3 space-y-3","children":[["$","p","You can review and update parts of your account information inside the product. You may also contact us if you want to request access, correction, deletion, or help with an account-related privacy issue.",{"className":"text-sm leading-7 text-[var(--text-secondary)] sm:text-base","children":"You can review and update parts of your account information inside the product. You may also contact us if you want to request access, correction, deletion, or help with an account-related privacy issue."}],["$","p","We may ask you to verify your identity before completing a request, and we may keep limited information where the law requires it or where we need it for fraud prevention, dispute resolution, or enforcement purposes.",{"className":"text-sm leading-7 text-[var(--text-secondary)] sm:text-base","children":"We may ask you to verify your identity before completing a request, and we may keep limited information where the law requires it or where we need it for fraud prevention, dispute resolution, or enforcement purposes."}]]}],null]}]
17:["$","section","6. Security and international processing",{"className":"card p-5 sm:p-6","children":[["$","h2",null,{"className":"text-xl font-black text-[var(--text-primary)]","children":"6. Security and international processing"}],["$","div",null,{"className":"mt-3 space-y-3","children":[["$","p","We use reasonable administrative, technical, and organizational safeguards to protect personal information. No method of storage or transmission is completely secure, so we cannot guarantee absolute security.",{"className":"text-sm leading-7 text-[var(--text-secondary)] sm:text-base","children":"We use reasonable administrative, technical, and organizational safeguards to protect personal information. No method of storage or transmission is completely secure, so we cannot guarantee absolute security."}],["$","p","Mechi may use providers in more than one country to host infrastructure, process payments, or deliver support tools. By using the service, you understand that information may be processed outside your home country where different data protection rules may apply.",{"className":"text-sm leading-7 text-[var(--text-secondary)] sm:text-base","children":"Mechi may use providers in more than one country to host infrastructure, process payments, or deliver support tools. By using the service, you understand that information may be processed outside your home country where different data protection rules may apply."}]]}],null]}]
18:["$","section","7. Children and policy updates",{"className":"card p-5 sm:p-6","children":[["$","h2",null,{"className":"text-xl font-black text-[var(--text-primary)]","children":"7. Children and policy updates"}],["$","div",null,{"className":"mt-3 space-y-3","children":[["$","p","Mechi is not intended for children under 13, and we do not knowingly collect personal information from children under 13. If you believe a child has provided personal information to us, please contact us so we can investigate and take appropriate action.",{"className":"text-sm leading-7 text-[var(--text-secondary)] sm:text-base","children":"Mechi is not intended for children under 13, and we do not knowingly collect personal information from children under 13. If you believe a child has provided personal information to us, please contact us so we can investigate and take appropriate action."}],["$","p","We may update this Privacy Policy from time to time. When we make material changes, we may revise the date above and provide additional notice inside the product or through other reasonable channels.",{"className":"text-sm leading-7 text-[var(--text-secondary)] sm:text-base","children":"We may update this Privacy Policy from time to time. When we make material changes, we may revise the date above and provide additional notice inside the product or through other reasonable channels."}]]}],null]}]
