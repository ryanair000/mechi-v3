{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/notifications/layout,_N_T_/(app)/notifications/page,_N_T_/notifications"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/notifications/__PAGE__",
    "/!KGFwcCk/notifications",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}