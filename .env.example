# Existing app secrets omitted here for brevity.
# Add the values below to your local or hosted environment before enabling Instagram DMs.

INSTAGRAM_GRAPH_API_VERSION=v25.0
# Used by /api/webhooks/instagram and /api/instagram/webhook.
INSTAGRAM_VERIFY_TOKEN=replace-with-a-random-shared-secret
# Optional alias; when blank, INSTAGRAM_VERIFY_TOKEN is used.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=replace-with-a-random-shared-secret
INSTAGRAM_APP_SECRET=your-meta-app-secret
MECHI_INSTAGRAM_ACCESS_TOKEN=your-instagram-user-token
MECHI_INSTAGRAM_USER_ID=your-instagram-professional-account-id
MECHI_INSTAGRAM_APP_ID=your-meta-app-id
MECHI_INSTAGRAM_APP_SECRET=your-meta-app-secret
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_PAGE_ACCESS_TOKEN=your-page-access-token-with-instagram-messaging-access
INSTAGRAM_AI_AUTO_REPLY_ENABLED=false

OPENCLAW_WEBHOOK_URL=https://smm-api.lokimax.top/webhooks/instagram
OPENCLAW_API_KEY=
OPENCLAW_TIMEOUT_MS=15000
MECHI_OPENCLAW_BRIDGE_URL=https://smm-api.lokimax.top/v1/mechi-support-reply
MECHI_OPENCLAW_BRIDGE_TOKEN=
INSTAGRAM_FALLBACK_REPLY=

# Meta WhatsApp Cloud API.
# Transport for /api/whatsapp/webhook inbound DMs and Graph API outbound replies.
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_TOKEN=your-permanent-system-user-or-cloud-api-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-a-random-shared-secret
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_TEST_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_MATCH_FOUND=
WHATSAPP_TEMPLATE_RESULT_CONFIRMED=
WHATSAPP_TEMPLATE_MATCH_DISPUTE=
WHATSAPP_TEMPLATE_CHALLENGE_RECEIVED=
WHATSAPP_TEMPLATE_PLAYMECHI_REGISTRATION=
WHATSAPP_TEMPLATE_PLAYMECHI_REMINDER=

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@mechi.club

TELEGRAM_BOT_TOKEN=
# Telegram supergroup or channel chat id. For groups this is usually a negative -100... id.
TELEGRAM_CHAT_ID=
# Optional topic id inside the Telegram group for new registrations.
TELEGRAM_REGISTRATION_THREAD_ID=
# Optional topic id inside the Telegram group for new test issue reports and fixed updates.
TELEGRAM_TEST_REPORT_THREAD_ID=
# Optional display names used in Telegram test report notifications.
TELEGRAM_TEST_REPORTER_LABEL=
TELEGRAM_TEST_FIXER_LABEL=

# Optional dedicated Telegram token for the EC2 OpenClaw host poller.
# Falls back to TELEGRAM_BOT_TOKEN when omitted.
MECHI_OPENCLAW_TELEGRAM_BOT_TOKEN=
# Native OpenClaw Telegram is preferred on EC2. "auto" enables it when a bot token is present.
MECHI_OPENCLAW_TELEGRAM_NATIVE_ENABLED=auto
MECHI_OPENCLAW_TELEGRAM_OPERATOR_IDS=6806783421,6738706706
# Negative Telegram group/supergroup ids. Control groups route to the repo-capable control agent.
MECHI_OPENCLAW_TELEGRAM_CONTROL_GROUP_IDS=
MECHI_OPENCLAW_TELEGRAM_COMMUNITY_GROUP_IDS=
MECHI_OPENCLAW_TELEGRAM_REGISTRATION_TOPIC_ID=
MECHI_OPENCLAW_TELEGRAM_DEFAULT_GROUP_AGENT=community
MECHI_OPENCLAW_TELEGRAM_COMMUNITY_GROUP_MENTION_REQUIRED=true
MECHI_OPENCLAW_TELEGRAM_OPS_GROUP_MENTION_REQUIRED=false
MECHI_OPENCLAW_KEEP_TELEGRAM_POLLER=false
# support = customer-safe Telegram helper with built-in Mechi product context.
# direct = operator control chat; pair with MECHI_OPENCLAW_TELEGRAM_AGENT=default/main and an allowlist.
MECHI_OPENCLAW_TELEGRAM_MODE=support
# Use support for customer-safe replies, or default/main for full-control repo access in direct mode.
MECHI_OPENCLAW_TELEGRAM_AGENT=support
MECHI_OPENCLAW_TELEGRAM_MODEL=openai-codex/gpt-5.5
MECHI_OPENCLAW_TELEGRAM_TIMEOUT_SECONDS=120
MECHI_OPENCLAW_TELEGRAM_POLL_TIMEOUT_SECONDS=25
MECHI_OPENCLAW_TELEGRAM_RETRY_DELAY_MS=3000
MECHI_OPENCLAW_TELEGRAM_ALLOWED_CHAT_TYPES=private,group,supergroup
MECHI_OPENCLAW_TELEGRAM_GROUP_REQUIRE_MENTION=true
# Optional comma-separated Telegram chat ids allowed to talk to the poller.
MECHI_OPENCLAW_TELEGRAM_ALLOWED_CHAT_IDS=
MECHI_OPENCLAW_TELEGRAM_DELETE_WEBHOOK=true

# Local Windows OpenClaw gateways should stay off for Mechi production.
# EC2 is the single live OpenClaw gateway/bridge owner.
MECHI_OPENCLAW_RUNTIME=ec2
MECHI_OPENCLAW_PUBLIC_BASE_URL=https://smm-api.lokimax.top
# Native OpenClaw WhatsApp uses only the support account by default.
# Leave primary native account values empty unless deliberately adding another logged-in account.
MECHI_NATIVE_WHATSAPP_NUMBER=
MECHI_NATIVE_WHATSAPP_ACCOUNT_ID=
MECHI_NATIVE_SUPPORT_WHATSAPP_NUMBER=+254733638841
MECHI_NATIVE_SUPPORT_WHATSAPP_ACCOUNT_ID=default

NEXT_PUBLIC_APP_URL=https://mechi.club
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Used by the OpenClaw control agent live registration helper:
# npm run ops:registrations -- --json
GH_TOKEN=
GITHUB_TOKEN=
GH_REPO=ryanair000/mechi-v3
# Used by the OpenClaw control agent GitHub skill and gh CLI wiring.
MECHI_OBSIDIAN_VAULT=mechi-ops
MECHI_OBSIDIAN_VAULT_PATH=/home/ubuntu/.openclaw/vaults/mechi-ops
EDITOR=/usr/bin/cat
# Used by the OpenClaw control agent Obsidian skill on the headless host.
NEXT_PUBLIC_TESTS_URL=https://tests.mechi.club
NEXT_PUBLIC_WHATSAPP_JOIN_URL=
NEXT_PUBLIC_CHEZAHUB_URL=
NEXT_PUBLIC_MUX_ENV_KEY=
NEXT_PUBLIC_PLAYMECHI_YOUTUBE_EMBED_URL=
NEXT_PUBLIC_PLAYMECHI_YOUTUBE_VIDEO_ID=
NEXT_PUBLIC_PLAYMECHI_YOUTUBE_CHANNEL_ID=

MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=

# OpenClaw ClawHub provider credentials.
# Installing a skill does not grant provider access; add these only on the EC2 host when enabling live API calls.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2

GA4_PROPERTY_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=
SEARCH_CONSOLE_SITE_URL=
GA4_DEFAULT_DATE_RANGE=30d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
IMGUR_CLIENT_ID=
FACEBOOK_USER_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

MATON_API_KEY=
# Paystack ClawHub access is handled through Membrane OAuth/login, not a static repo env var by default.
