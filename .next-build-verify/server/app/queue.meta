{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/queue/layout,_N_T_/(app)/queue/page,_N_T_/queue"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/queue/__PAGE__",
    "/!KGFwcCk/queue",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}