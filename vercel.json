{
  "functions": {
    "src/app/api/**": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/matchmaking",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
