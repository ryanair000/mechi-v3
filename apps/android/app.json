{
  "expo": {
    "name": "PlayMechi",
    "slug": "mechi-android",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mechi",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070a08"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.mechi.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070a08"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "http://10.0.2.2:3000",
      "router": {},
      "eas": {
        "projectId": "a10d1b1e-45f9-41f5-8408-3d281c00b837"
      }
    },
    "owner": "ryanair001"
  }
}
